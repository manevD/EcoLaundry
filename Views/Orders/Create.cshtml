@using EcoLaundry.Entities
@using System.Text.Json

@model Order

@{
    ViewData["Title"] = "Нова нарачка";

    var categories =
        ViewBag.Categories as List<LaundryCategory>
        ?? new List<LaundryCategory>();

    var customersJson =
        JsonSerializer.Serialize(ViewBag.Customers);

var selectedCustomerJson =
    JsonSerializer.Serialize((object)ViewBag.SelectedCustomer);

    var categoriesJson =
        JsonSerializer.Serialize(
            categories.Select(x => new
            {
                x.Id,
                x.Name
            })
        );
}


<div class="container-fluid">

    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="mb-3">Нова нарачка</h4>


            <form asp-action="Create" method="post">


                <!-- CUSTOMER -->

                <div class="mb-3">

                    <label>Клиент</label>

                    <input id="customerSearch"
                           class="form-control form-control-lg"
                           placeholder="🔍 Барај клиент..." />

                    <input type="hidden"
                           asp-for="CustomerId"
                           id="CustomerId" />

                    <div id="customerResults"
                         class="list-group mt-2">
                    </div>

                </div>




                <!-- EXPRESS -->

                <div class="form-check form-switch mb-3">

                    <input asp-for="IsExpress"
                           class="form-check-input"
                           style="width:50px;height:25px;" />

                    <label class="ms-2">
                        🔥 Express
                    </label>

                </div>





                <!-- DATES -->

                <div class="mb-3">

                    <label>⏳ Очекувано готово</label>

                    <input name="ExpectedFinishDate"
                           type="datetime-local"
                           value="@(Model.ExpectedFinishDate?.ToString("yyyy-MM-ddTHH:mm"))"
                           class="form-control" />

                </div>


                <div class="mb-3">

                    <label>✅ Завршено</label>

                    <input name="FinishedDate"
                           type="datetime-local"
                           value="@(Model.FinishedDate?.ToString("yyyy-MM-ddTHH:mm"))"
                           class="form-control" />

                </div>





                <!-- NOTES -->

                <div class="mb-3">

                    <label>📝 Забелешка</label>

                    <textarea asp-for="Notes"
                              rows="3"
                              class="form-control">
</textarea>

                </div>





                <hr />

                <h5>👕 Облека</h5>


                <input id="categorySearch"
                       class="form-control form-control-lg mb-2"
                       placeholder="🔍 Барај категорија..." />


                <div id="categoryResults"
                     class="list-group mb-3">
                </div>


                <div id="items">
                </div>






                <div class="alert alert-success">

                    Вкупно:

                    <strong>
                        <span id="totalPrice">0</span> ден
                    </strong>

                </div>





                <div class="d-grid gap-2">

                    <button class="btn btn-primary btn-lg">

                        💾 Зачувај

                    </button>


                    <a asp-action="Index"
                       class="btn btn-outline-secondary">

                        Назад

                    </a>


                </div>


            </form>

        </div>
    </div>

</div>


<script>

    const customers = @Html.Raw(customersJson);
    const selectedCustomer = @Html.Raw(selectedCustomerJson);
    const categories = @Html.Raw(categoriesJson);

    const customerSearch = document.getElementById("customerSearch");
    const customerResults = document.getElementById("customerResults");
    const customerId = document.getElementById("CustomerId");

    const categorySearch = document.getElementById("categorySearch");
    const categoryResults = document.getElementById("categoryResults");

    const items = document.getElementById("items");
    const totalPrice = document.getElementById("totalPrice");

        function normalize(text) {

        if (!text) return "";

        let value = text.toLowerCase();

        const map = [
            ["љ","lj"],["њ","nj"],["џ","dz"],["ѓ","gj"],["ќ","kj"],["ж","zh"],["ч","ch"],["ш","sh"],
            ["а","a"],["б","b"],["в","v"],["г","g"],["д","d"],["е","e"],["з","z"],["и","i"],
            ["ј","j"],["к","k"],["л","l"],["м","m"],["н","n"],["о","o"],["п","p"],["р","r"],
            ["с","s"],["т","t"],["у","u"],["ф","f"],["х","h"],["ц","c"],["ѕ","dz"]
        ];

        map.forEach(([mk, lat]) => {
            value = value.replaceAll(mk, lat);
        });

        return value;
    }

    // selected customer

    if (selectedCustomer) {
        customerId.value = selectedCustomer.Id;
        customerSearch.value = selectedCustomer.Display;
    }

    // customer search

        customerSearch.addEventListener("input", function () {

        const value = normalize(this.value);

        customerResults.innerHTML = "";

        if (value.length < 2)
            return;

        customers
            .filter(c => {

                const display = normalize(c.Display);

                return display.includes(value);

            })
            .slice(0, 10)
            .forEach(c => {

                const btn = document.createElement("button");

                btn.type = "button";
                btn.className = "list-group-item list-group-item-action";
                btn.textContent = c.Display;

                btn.onclick = () => {

                    customerId.value = c.Id;
                    customerSearch.value = c.Display;
                    customerResults.innerHTML = "";

                };

                customerResults.appendChild(btn);

            });

    });

    // category search

    categorySearch.addEventListener("input", function () {

        const value = normalize(this.value);

        categoryResults.innerHTML = "";

        if (value.length < 1)
            return;

        categories
            .filter(x => normalize(x.Name).includes(value))
            .slice(0, 10)
            .forEach(c => {

                const btn = document.createElement("button");

                btn.type = "button";
                btn.className = "list-group-item list-group-item-action";
                btn.textContent = c.Name;

                btn.onclick = () => {

                    addItem(c.Id, c.Name);

                    categorySearch.value = "";
                    categoryResults.innerHTML = "";

                };

                categoryResults.appendChild(btn);

            });

    });

    // add item

    function addItem(id, name) {

        items.insertAdjacentHTML("beforeend", `
    <div class="card mb-2 item-row">

    <div class="card-body">

    <strong>${name}</strong>

    <input type="hidden"
           name="categoryIds"
           value="${id}">

    <div class="row mt-3">

    <div class="col-4">

    <input type="number"
           name="quantities"
           min="1"
           value="1"
           class="form-control quantity-input">

    </div>

    <div class="col-6">

    <input type="number"
           name="prices"
           value="0"
           class="form-control price-input">

    </div>

    <div class="col-2">

    <button type="button"
            class="btn btn-danger remove">

    ✕
    </button>

    </div>

    </div>

    </div>

    </div>
    `);

        calculateTotal();

    }

    // total

    function calculateTotal() {

        let total = 0;

        document.querySelectorAll(".item-row").forEach(row => {

            const qty = Number(row.querySelector(".quantity-input").value) || 0;
            const price = Number(row.querySelector(".price-input").value) || 0;

            total += qty * price;

        });

        totalPrice.textContent = total.toLocaleString("mk-MK");

    }

    // quantity / price

    document.addEventListener("input", function (e) {

        if (
            e.target.classList.contains("quantity-input") ||
            e.target.classList.contains("price-input")
        ) {

            calculateTotal();

        }

    });

    // remove

    document.addEventListener("click", function (e) {

        if (e.target.classList.contains("remove")) {

            e.target.closest(".item-row").remove();

            calculateTotal();

        }

    });

    calculateTotal();

</script>