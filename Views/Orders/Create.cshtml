@using EcoLaundry.Entities
@using System.Text.Json

@model Order

@{
    ViewData["Title"] = "Нова нарачка";

    var categories =
        ViewBag.Categories as List<LaundryCategory>
        ?? new List<LaundryCategory>();

    var customersJson =
        JsonSerializer.Serialize(ViewBag.Customers);

    var selectedCustomerJson =
        JsonSerializer.Serialize(ViewBag.SelectedCustomer);

    var categoriesJson =
        JsonSerializer.Serialize(
            categories.Select(x => new
            {
                x.Id,
                x.Name
            })
        );
}


<div class="container-fluid">

    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="mb-3">Нова нарачка</h4>


            <form asp-action="Create" method="post">


                <!-- CUSTOMER -->

                <div class="mb-3">

                    <label>Клиент</label>

                    <input id="customerSearch"
                           class="form-control form-control-lg"
                           placeholder="🔍 Барај клиент..." />

                    <input type="hidden"
                           asp-for="CustomerId"
                           id="CustomerId" />

                    <div id="customerResults"
                         class="list-group mt-2">
                    </div>

                </div>




                <!-- EXPRESS -->

                <div class="form-check form-switch mb-3">

                    <input asp-for="IsExpress"
                           class="form-check-input"
                           style="width:50px;height:25px;" />

                    <label class="ms-2">
                        🔥 Express
                    </label>

                </div>





                <!-- DATES -->

                <div class="mb-3">

                    <label>⏳ Очекувано готово</label>

                    <input name="ExpectedFinishDate"
                           type="datetime-local"
                           value="@(Model.ExpectedFinishDate?.ToString("yyyy-MM-ddTHH:mm"))"
                           class="form-control" />

                </div>


                <div class="mb-3">

                    <label>✅ Завршено</label>

                    <input name="FinishedDate"
                           type="datetime-local"
                           value="@(Model.FinishedDate?.ToString("yyyy-MM-ddTHH:mm"))"
                           class="form-control" />

                </div>





                <!-- NOTES -->

                <div class="mb-3">

                    <label>📝 Забелешка</label>

                    <textarea asp-for="Notes"
                              rows="3"
                              class="form-control">
</textarea>

                </div>





                <hr />

                <h5>👕 Облека</h5>


                <input id="categorySearch"
                       class="form-control form-control-lg mb-2"
                       placeholder="🔍 Барај категорија..." />


                <div id="categoryResults"
                     class="list-group mb-3">
                </div>


                <div id="items">
                </div>






                <div class="alert alert-success">

                    Вкупно:

                    <strong>
                        <span id="totalPrice">0</span> ден
                    </strong>

                </div>





                <div class="d-grid gap-2">

                    <button class="btn btn-primary btn-lg">

                        💾 Зачувај

                    </button>


                    <a asp-action="Index"
                       class="btn btn-outline-secondary">

                        Назад

                    </a>


                </div>


            </form>

        </div>
    </div>

</div>








@section Scripts {

    <partial name="_ValidationScriptsPartial" />


    <script>


        const customers =
        @Html.Raw(customersJson);


        const selectedCustomer =
        @Html.Raw(selectedCustomerJson);


        const categories =
        @Html.Raw(categoriesJson);




        // SET SELECTED CUSTOMER

        if(selectedCustomer)
        {

        CustomerId.value =
        selectedCustomer.Id;


        customerSearch.value =
        selectedCustomer.Display;

        }






        // CUSTOMER SEARCH

        customerSearch.addEventListener("input",()=>{


        let value =
        customerSearch.value.toLowerCase();


        customerResults.innerHTML="";


        if(value.length < 2)
        return;



        customers
        .filter(x=>x.Display.toLowerCase().includes(value))
        .slice(0,10)
        .forEach(c=>{


        let btn =
        document.createElement("button");


        btn.type="button";


        btn.className =
        "list-group-item list-group-item-action";


        btn.innerText =
        c.Display;



        btn.onclick=()=>{


        CustomerId.value =
        c.Id;


        customerSearch.value =
        c.Display;


        customerResults.innerHTML="";


        };



        customerResults.appendChild(btn);


        });


        });








        // CATEGORY SEARCH

        categorySearch.addEventListener("input",()=>{


        let value =
        categorySearch.value.toLowerCase();


        categoryResults.innerHTML="";


        if(value.length < 1)
        return;



        categories
        .filter(x=>x.Name.toLowerCase().includes(value))
        .slice(0,10)
        .forEach(c=>{


        let btn =
        document.createElement("button");


        btn.type="button";


        btn.className =
        "list-group-item list-group-item-action";


        btn.innerText =
        c.Name;



        btn.onclick=()=>{


        addItem(
        c.Id,
        c.Name
        );


        categorySearch.value="";

        categoryResults.innerHTML="";


        };



        categoryResults.appendChild(btn);


        });


        });








        // ADD ITEM

        function addItem(id,name)
        {


        items.insertAdjacentHTML(
        "beforeend",
        `

        <div class="card mb-2 item-row">

        <div class="card-body py-2">

        <strong>${name}</strong>


        <input type="hidden"
        name="categoryIds"
        value="${id}">


        <div class="row mt-2">


        <div class="col-4">

        <input name="quantities"
        type="number"
        min="1"
        value="1"
        class="form-control quantity-input">

        </div>


        <div class="col-6">

        <input name="prices"
        type="number"
        value="0"
        class="form-control price-input">

        </div>


        <div class="col-2">

        <button type="button"
        class="btn btn-danger remove">

        X

        </button>

        </div>


        </div>
        </div>
        </div>

        `
        );


        calculateTotal();

        }









        // TOTAL

        function calculateTotal()
        {


        let total=0;


        document
        .querySelectorAll(".item-row")
        .forEach(row=>{


        let q =
        row.querySelector(".quantity-input").value;


        let p =
        row.querySelector(".price-input").value;


        total +=
        Number(q) * Number(p);


        });


        totalPrice.innerText =
        total;


        }








        // CHANGE PRICE OR QUANTITY

        document.addEventListener("input",e=>{


        if(
        e.target.classList.contains("quantity-input")
        ||
        e.target.classList.contains("price-input")
        )
        calculateTotal();


        });






        // REMOVE ITEM

        document.addEventListener("click",e=>{


        if(e.target.classList.contains("remove"))
        {

        e.target.closest(".item-row").remove();

        calculateTotal();

        }


        });



        calculateTotal();


    </script>

}