@using EcoLaundry.Entities
@model IEnumerable<Customer>

@{
    ViewData["Title"] = "Клиенти";
    var customers = Model ?? Enumerable.Empty<Customer>();
}


<div class="container-fluid">


    <div class="d-flex justify-content-between align-items-center mb-3">

        <h4 class="mb-0">
            Клиенти
        </h4>


        <a asp-action="Create"
           class="btn btn-primary btn-sm">
            + Нов клиент
        </a>

    </div>



    <!-- LIVE SEARCH -->

    <div class="mb-3">

        <input type="text"
               id="searchInput"
               class="form-control form-control-lg"
               placeholder="🔍 Барај по име или телефон..." />

    </div>





    <!-- MOBILE VIEW -->

    <div class="d-md-none"
         id="mobileCustomers">

        @foreach (var item in Model)
        {
            <div class="card shadow-sm mb-3 customer-card">


                <div class="card-body">


                    <h5 class="card-title mb-1">

                        @item.FirstName @item.LastName

                    </h5>


                    <p class="text-muted mb-2">

                        📞 @item.Phone

                    </p>



                    <small class="text-muted">

                        Нарачки:
                        @item.Orders.Count

                    </small>



                    <div class="mt-3 d-flex gap-2">


                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            Детали
                        </a>



                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-outline-secondary btn-sm flex-fill">
                            Измени
                        </a>


                    </div>


                </div>


            </div>
        }


    </div>







    <!-- DESKTOP VIEW -->

    <div class="table-responsive d-none d-md-block">


        <table class="table table-hover align-middle"
               id="customersTable">


            <thead>

                <tr>

                    <th>Име</th>

                    <th>Телефон</th>

                    <th>Нарачки</th>

                    <th class="text-end">
                        Акција
                    </th>

                </tr>

            </thead>



            <tbody>


                @foreach (var item in customers)
                {

                    <tr>


                        <td>

                            <strong>
                                @item.FirstName @item.LastName
                            </strong>

                        </td>


                        <td>

                            @item.Phone

                        </td>



                        <td>

                            <span class="badge bg-secondary">

                                @item.Orders.Count

                            </span>

                        </td>




                        <td class="text-end">


                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">

                                Детали

                            </a>



                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary">

                                Измени

                            </a>


                        </td>



                    </tr>

                }


            </tbody>


        </table>


    </div>


</div>






@section Scripts
{

    <script>


        const search =
            document.getElementById("searchInput");



        search.addEventListener(
            "keyup",
            function () {


                let value =
                    this.value.toLowerCase();




                // mobile cards

                document
                    .querySelectorAll(".customer-card")
                    .forEach(card => {


                        let text =
                            card.innerText.toLowerCase();



                        card.style.display =
                            text.includes(value)
                                ? ""
                                : "none";


                    });






                // desktop rows

                document
                    .querySelectorAll("#customersTable tbody tr")
                    .forEach(row => {


                        let text =
                            row.innerText.toLowerCase();

                        row.style.display =
                            text.includes(value)
                                ? ""
                                : "none";


                    });

            });


    </script>

}