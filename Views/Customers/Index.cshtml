@using EcoLaundry.Entities
@model IEnumerable<Customer>

@{
    ViewData["Title"] = "Клиенти";
    var customers = Model ?? Enumerable.Empty<Customer>();
}


<div class="container-fluid">


    <div class="d-flex justify-content-between align-items-center mb-3">

        <h4 class="mb-0">
            Клиенти
        </h4>


        <a asp-action="Create"
           class="btn btn-primary btn-sm">
            + Нов клиент
        </a>

    </div>



    <!-- LIVE SEARCH -->

    <div class="mb-3">

        <input type="text"
               id="searchInput"
               class="form-control form-control-lg"
               placeholder="🔍 Барај по име или телефон..." />

    </div>





    <!-- MOBILE VIEW -->

    <div class="d-md-none"
         id="mobileCustomers">

        @foreach (var item in Model)
        {
            <div class="card shadow-sm mb-3 customer-card">


                <div class="card-body">


                    <h5 class="card-title mb-1">

                        @item.FirstName @item.LastName

                    </h5>


                    <p class="text-muted mb-2">

                        📞 @item.Phone

                    </p>



                    <small class="text-muted">

                        Нарачки:
                        @item.Orders.Count

                    </small>



                    <div class="mt-3 d-flex gap-2">


                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            Детали
                        </a>



                        <a asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-outline-secondary btn-sm flex-fill">
                            Измени
                        </a>


                    </div>


                </div>


            </div>
        }


    </div>







    <!-- DESKTOP VIEW -->

    <div class="table-responsive d-none d-md-block">


        <table class="table table-hover align-middle"
               id="customersTable">


            <thead>

                <tr>

                    <th>Име</th>

                    <th>Телефон</th>

                    <th>Нарачки</th>

                    <th class="text-end">
                        Акција
                    </th>

                </tr>

            </thead>



            <tbody>


                @foreach (var item in customers)
                {

                    <tr>


                        <td>

                            <strong>
                                @item.FirstName @item.LastName
                            </strong>

                        </td>


                        <td>

                            @item.Phone

                        </td>



                        <td>

                            <span class="badge bg-secondary">

                                @item.Orders.Count

                            </span>

                        </td>




                        <td class="text-end">


                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">

                                Детали

                            </a>



                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-secondary">

                                Измени

                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <button class="btn btn-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal"
                                        data-id="@item.Id"
                                        data-name="@item.FirstName">

                                    🗑️ Избриши

                                </button>

                            }

                        </td>



                    </tr>

                }


            </tbody>


        </table>


    </div>


</div>
<div class="modal fade" id="deleteModal" tabindex="-1">

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    ⚠️ Потврда за бришење
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <p id="deleteText"></p>

                <div class="alert alert-danger">

                    <strong>Внимание!</strong><br>

                    Со бришењето на клиентот ќе се избришат и сите негови нарачки.
                    Оваа акција не може да се врати.

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Откажи

                </button>

                <form id="deleteForm"
                      method="post">

                    @Html.AntiForgeryToken()

                    <button class="btn btn-danger">

                        🗑️ Избриши

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>
@section Scripts {

    <script>

        const deleteModal =
        document.getElementById('deleteModal');

        deleteModal.addEventListener('show.bs.modal', function (event) {

            const button = event.relatedTarget;

            const id = button.dataset.id;
            const name = button.dataset.name;

            document.getElementById("deleteText").innerHTML =
                `Дали сте сигурни дека сакате да го избришете клиентот <strong>${name}</strong>?`;

            document.getElementById("deleteForm").action =
                "/Customers/Delete/" + id;

        });

    </script>

    <script>

        attachSearch(
            "searchInput",
            ".customer-card");

        attachSearch(
            "searchInput",
            "#customersTable tbody tr");

    </script>

}